# PeakShield Configuration Example
# Copy this file to .env or export these variables in your shell before running PeakShield

# The port PeakShield will listen on
PEAKSHIELD_LISTEN_PORT=8080

# The target legacy backend URL (Required)
PEAKSHIELD_BACKEND_URL=http://localhost:9000

# The maximum number of simultaneous requests allowed to reach the backend
PEAKSHIELD_MAX_CONCURRENT=200

# The maximum number of clients to hold in the virtual waiting room queue
PEAKSHIELD_QUEUE_SIZE=500
